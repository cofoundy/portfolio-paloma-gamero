---
import { siteConfig } from "../config";
---

<section id="education" class="py-12 md:py-20 px-6 md:px-12">
  <div class="max-w-4xl mx-auto">
    {siteConfig.education.map(edu => (
      <div class="reveal text-center">
        <p class="label-upper mb-4">Education</p>
        <p class="text-lg md:text-xl font-semibold" style="font-family: var(--font-display);">
          {edu.degree}
        </p>
        {edu.extra && (
          <p class="text-sm mt-1" style="color: var(--color-text-light);">
            {edu.extra}
          </p>
        )}
        <p class="text-base mt-2" style="color: var(--color-accent);">
          {edu.school}
        </p>
        <p class="text-xs mt-2 uppercase tracking-wider" style="color: var(--color-text-light);">
          {edu.dateRange} &mdash; {edu.location}
          {edu.gpa && <span> &mdash; GPA {edu.gpa}</span>}
        </p>
      </div>
    ))}
  </div>
</section>
