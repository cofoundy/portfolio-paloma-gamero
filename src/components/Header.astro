---
import { siteConfig } from "../config";
const firstName = siteConfig.name.split(' ')[0];
---

<header id="main-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <nav class="max-w-[1400px] mx-auto px-6 md:px-12 py-5 flex items-center justify-between">
    <!-- Name (left) -->
    <a href="#hero" class="text-sm font-medium uppercase tracking-[0.15em]" style="color: var(--color-text);">
      {firstName}
    </a>

    <!-- Links (right) — desktop -->
    <div class="hidden md:flex items-center gap-8">
      {["About", "Work", "Experience", "Contact"].map(item => (
        item === "Work" ? (
          <a
            href="/resume-paloma-gamero.pdf"
            target="_blank"
            rel="noopener"
            class="text-xs uppercase tracking-[0.15em] transition-opacity hover:opacity-60"
            style="color: var(--color-text);"
          >
            Resumen
          </a>
        ) : (
          <a
            href={`#${item.toLowerCase()}`}
            class="text-xs uppercase tracking-[0.15em] transition-opacity hover:opacity-60"
            style="color: var(--color-text);"
          >
            {item}
          </a>
        )
      ))}
    </div>

    <!-- Mobile menu toggle -->
    <button id="mobile-toggle" class="md:hidden text-sm uppercase tracking-[0.15em]" style="color: var(--color-text);" aria-label="Menu">
      Menu
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden px-6 pb-6">
    <div class="flex flex-col gap-4">
      {["About", "Work", "Experience", "Contact"].map(item => (
        item === "Work" ? (
          <a
            href="/resume-paloma-gamero.pdf"
            target="_blank"
            rel="noopener"
            class="mobile-nav-link text-sm uppercase tracking-[0.15em] py-2"
            style="color: var(--color-text);"
          >
            Resumen
          </a>
        ) : (
          <a
            href={`#${item.toLowerCase()}`}
            class="mobile-nav-link text-sm uppercase tracking-[0.15em] py-2"
            style="color: var(--color-text);"
          >
            {item}
          </a>
        )
      ))}
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('main-header');
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');

  // Scroll effect
  window.addEventListener('scroll', () => {
    if (!header) return;
    if (window.scrollY > 80) {
      header.classList.add('header-scrolled');
    } else {
      header.classList.remove('header-scrolled');
    }
  });

  // Mobile toggle
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // Close mobile menu on link click
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
    });
  });
</script>
