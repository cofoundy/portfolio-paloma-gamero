---
import { siteConfig } from "../config";
---

<footer id="contact" class="py-20 md:py-32 px-6 md:px-12">
  <div class="max-w-6xl mx-auto text-center">
    <!-- Giant CTA -->
    <div class="reveal">
      <p class="label-upper mb-6">Get in Touch</p>
      <h2 class="display-large mb-10">
        LET'S WORK<br />TOGETHER
      </h2>
    </div>

    <!-- Contact info -->
    <div class="reveal stagger-1 flex flex-col items-center gap-4 mb-12">
      <a
        href={`mailto:${siteConfig.social.email}`}
        class="editorial-link text-lg md:text-xl"
        style="font-family: var(--font-body);"
      >
        {siteConfig.social.email}
      </a>

      <p class="text-sm" style="color: var(--color-text-light);">
        Kansas City, MO
      </p>
    </div>

    <!-- Social links -->
    <div class="reveal stagger-2 flex justify-center gap-8 mb-16">
      <a
        href={siteConfig.social.linkedin}
        target="_blank"
        rel="noopener"
        class="text-sm uppercase tracking-[0.15em] transition-opacity hover:opacity-60"
        style="color: var(--color-text);"
      >
        LinkedIn
      </a>
      {siteConfig.social.instagram && (
        <a
          href={siteConfig.social.instagram}
          target="_blank"
          rel="noopener"
          class="text-sm uppercase tracking-[0.15em] transition-opacity hover:opacity-60"
          style="color: var(--color-text);"
        >
          Instagram
        </a>
      )}
      <a
        href={`mailto:${siteConfig.social.email}`}
        class="text-sm uppercase tracking-[0.15em] transition-opacity hover:opacity-60"
        style="color: var(--color-text);"
      >
        Email
      </a>
    </div>

    <!-- Copyright -->
    <div class="pt-8 border-t" style="border-color: rgba(26,26,26,0.1);">
      <p class="text-xs" style="color: var(--color-text-light);">
        &copy; {new Date().getFullYear()} {siteConfig.name}
      </p>
    </div>
  </div>
</footer>
