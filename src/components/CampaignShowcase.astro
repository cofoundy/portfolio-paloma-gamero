---
import { siteConfig } from "../config";
---

<section id="work" class="py-20 md:py-32 px-8" style="background-color: var(--color-light);">
  <div class="max-w-6xl mx-auto">
    <!-- Section Header -->
    <div class="mb-16 reveal">
      <p class="text-xs uppercase tracking-[0.25em] mb-3 font-medium" style="color: var(--color-warm); font-family: 'Inter', sans-serif;">
        Portfolio
      </p>
      <h2 class="text-4xl md:text-5xl lg:text-6xl leading-[0.95]" style="font-family: 'DM Serif Display', serif; color: var(--color-slate);">
        My Work
      </h2>
      <div class="editorial-line mt-6"></div>
    </div>

    <!-- Brands -->
    <div class="space-y-20">
      {siteConfig.brands.map((brand, brandIndex) => (
        <div class={`reveal stagger-${brandIndex + 1}`}>
          <!-- Brand Header -->
          <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-4 mb-8">
            <div>
              <h3 class="text-2xl md:text-3xl" style="font-family: 'DM Serif Display', serif; color: var(--color-slate);">
                {brand.name}
              </h3>
              <p class="text-xs uppercase tracking-[0.15em] mt-2 font-medium" style="color: var(--color-warm); font-family: 'Inter', sans-serif;">
                {brand.type}
              </p>
            </div>
            <p class="text-sm leading-relaxed max-w-md" style="color: var(--color-accent);">
              {brand.description}
            </p>
          </div>

          <!-- Image Grid -->
          <div class={`grid gap-4 ${brand.images.length === 3 ? 'grid-cols-2 md:grid-cols-3' : brand.images.length === 2 ? 'grid-cols-2' : 'grid-cols-1'}`}>
            {brand.images.map((image, imgIndex) => (
              <div
                class={`reveal-scale stagger-${imgIndex + 1} group relative overflow-hidden rounded-none ${brand.images.length === 3 && imgIndex === 0 ? 'col-span-2 md:col-span-1' : ''}`}
              >
                <div class="aspect-[4/3] overflow-hidden" style="background-color: var(--color-cream);">
                  <img
                    src={image.src}
                    alt={image.alt}
                    class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
              </div>
            ))}
          </div>

          {/* Separator line between brands */}
          {brandIndex < siteConfig.brands.length - 1 && (
            <div class="mt-16 flex items-center gap-4">
              <div class="h-px grow" style="background-color: var(--color-warm); opacity: 0.3;"></div>
              <span class="text-[10px] uppercase tracking-[0.2em] font-medium" style="color: var(--color-warm); font-family: 'Inter', sans-serif;">
                {String(brandIndex + 2).padStart(2, '0')}
              </span>
              <div class="h-px grow" style="background-color: var(--color-warm); opacity: 0.3;"></div>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
