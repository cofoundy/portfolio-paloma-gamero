---
import { siteConfig } from "../config";

function getEmbedUrl(url: string): string {
  const match = url.match(/shorts\/([a-zA-Z0-9_-]+)/);
  if (match) return `https://www.youtube.com/embed/${match[1]}`;
  return url;
}
---

<section id="work" class="section-dark py-20 md:py-32 px-6 md:px-12">
  <div class="max-w-6xl mx-auto">
    <!-- Section title -->
    <div class="mb-16 md:mb-20 reveal">
      <p class="label-upper mb-4" style="color: #888;">Selected Work</p>
      <h2 class="display-large">PAST PROJECTS</h2>
    </div>

    <!-- Brand sections -->
    <div class="space-y-20 md:space-y-28">
      {siteConfig.brands.map((brand, i) => (
        <div class="reveal stagger-1">
          <!-- Brand header -->
          <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-2 mb-6 md:mb-8">
            <div>
              <h3 class="text-2xl md:text-3xl font-bold" style="font-family: var(--font-display); color: #f3eeed;">
                {brand.name}
              </h3>
              <span class="text-xs uppercase tracking-[0.2em] mt-1 inline-block" style="color: #888;">
                {brand.type}
              </span>
            </div>
            <span class="text-sm" style="color: #666; font-family: var(--font-body);">
              {String(i + 1).padStart(2, '0')} / {String(siteConfig.brands.length).padStart(2, '0')}
            </span>
          </div>

          <!-- Description -->
          <p class="text-base md:text-lg leading-relaxed mb-8 max-w-3xl" style="color: #aaa;">
            {brand.description}
          </p>

          <!-- Image grid -->
          <div class={`grid gap-3 ${brand.images.length >= 3 ? 'grid-cols-2 md:grid-cols-3' : brand.images.length === 2 ? 'grid-cols-2' : 'grid-cols-1'}`}>
            {brand.images.map((image) => (
              <div class="img-hover overflow-hidden rounded-sm">
                <img
                  src={image.src}
                  alt={image.alt}
                  class="w-full h-auto"
                  loading="lazy"
                />
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Video Reels -->
    {siteConfig.videos && siteConfig.videos.length > 0 && (
      <div class="mt-24 md:mt-32 reveal">
        <div class="mb-10">
          <p class="label-upper mb-4" style="color: #888;">Video Content</p>
          <h3 class="text-2xl md:text-3xl font-bold" style="font-family: var(--font-display); color: #f3eeed;">
            Reels & Campaigns
          </h3>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {siteConfig.videos.map((video) => (
            <div class="aspect-[9/16] rounded-sm overflow-hidden">
              <iframe
                src={getEmbedUrl(video.url)}
                title={video.title}
                class="w-full h-full"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
              ></iframe>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</section>
