---
import { siteConfig } from "../config";

// Campaign type colors for visual variety
const typeColors: Record<string, string> = {
  "Graphics & Social Media": "bg-teal-50 text-teal-700",
  "Event Promotion": "bg-amber-50 text-amber-700",
  "Social Media & Design": "bg-indigo-50 text-indigo-700",
  "Photo & Video": "bg-rose-50 text-rose-700",
};

// Campaign placeholder patterns (SVG-based, no external images needed)
const patterns = [
  { bg: "#f0fdfa", accent: "#0d9488", icon: "M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" },
  { bg: "#fffbeb", accent: "#d97706", icon: "M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" },
  { bg: "#eef2ff", accent: "#6366f1", icon: "M7 4V2a1 1 0 011-1h8a1 1 0 011 1v2m-2 12l-4-4m0 0l-4 4m4-4V4M5 20h14a2 2 0 002-2v-5a2 2 0 00-2-2H5a2 2 0 00-2 2v5a2 2 0 002 2z" },
  { bg: "#fff1f2", accent: "#e11d48", icon: "M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" },
];
---

<section id="work" class="py-16 md:py-24 px-6 md:px-24" style="background-color: var(--color-surface);">
  <div class="max-w-5xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16">
      <!-- Heading -->
      <div class="lg:col-span-4 reveal">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-4">My Work</h2>
        <div class="accent-bar"></div>
        <p class="mt-4 text-gray-500 text-base">
          Visual campaigns that connect cultures and drive engagement.
        </p>
      </div>

      <!-- Campaign Grid -->
      <div class="lg:col-span-8 space-y-6">
        {siteConfig.campaigns.map((campaign, i) => (
          <div class={`reveal stagger-${i + 1} campaign-card group rounded-xl border border-gray-200 bg-white overflow-hidden card-hover`}>
            <!-- Visual placeholder area -->
            <div
              class="relative h-48 md:h-56 flex items-center justify-center"
              style={`background-color: ${patterns[i % patterns.length].bg};`}
            >
              <!-- Placeholder icon -->
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-16 h-16 opacity-20"
                fill="none"
                viewBox="0 0 24 24"
                stroke={patterns[i % patterns.length].accent}
                stroke-width="1.5"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d={patterns[i % patterns.length].icon}/>
              </svg>

              <!-- Overlay on hover -->
              <div class="campaign-overlay absolute inset-0 flex items-center justify-center" style={`background-color: ${patterns[i % patterns.length].accent}22;`}>
                <span class="text-sm font-medium px-4 py-2 rounded-full bg-white/90 text-gray-800 shadow-sm" style="font-family: 'IBM Plex Mono', monospace;">
                  Visual samples coming soon
                </span>
              </div>

              <!-- Type badge -->
              <span class={`absolute top-4 left-4 text-xs font-medium px-3 py-1 rounded-full ${typeColors[campaign.type] || 'bg-gray-100 text-gray-700'}`}
                    style="font-family: 'IBM Plex Mono', monospace;">
                {campaign.type}
              </span>
            </div>

            <!-- Card content -->
            <div class="p-6">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h3 class="text-lg md:text-xl font-bold text-gray-900 mb-1">{campaign.title}</h3>
                  <p class="text-sm font-medium mb-3" style="color: var(--color-accent); font-family: 'IBM Plex Mono', monospace;">
                    {campaign.client}
                  </p>
                </div>
                <span class="flex-shrink-0 text-sm text-gray-400" style="font-family: 'IBM Plex Mono', monospace;">
                  {String(i + 1).padStart(2, '0')}
                </span>
              </div>
              <p class="text-sm md:text-base text-gray-600 leading-relaxed">{campaign.description}</p>
            </div>
          </div>
        ))}

        <!-- Note about additional assets -->
        <div class="reveal stagger-5 text-center py-6">
          <p class="text-sm text-gray-400" style="font-family: 'IBM Plex Mono', monospace;">
            Additional graphics, photos & videos will be featured here
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
