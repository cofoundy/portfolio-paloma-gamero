---
import { siteConfig } from "../config";
---

<section id="experience" class="py-20 md:py-32 px-6 md:px-12">
  <div class="max-w-4xl mx-auto">
    <!-- Section heading -->
    <div class="mb-14 md:mb-18 reveal">
      <p class="label-upper mb-4">Career</p>
      <h2 class="display-medium">Experience</h2>
    </div>

    <!-- Clean list -->
    <div class="space-y-10 md:space-y-14">
      {siteConfig.experience.map((job, i) => (
        <div class={`reveal stagger-${Math.min(i + 1, 4)}`}>
          <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-1 mb-3">
            <div>
              <h3 class="text-lg md:text-xl font-bold" style="font-family: var(--font-display);">
                {job.company}
              </h3>
              <p class="text-base italic" style="color: var(--color-text-light);">
                {job.title}
              </p>
            </div>
            <div class="md:text-right">
              <p class="text-xs uppercase tracking-wider" style="color: var(--color-text-light);">
                {job.dateRange}
              </p>
              <p class="text-xs" style="color: var(--color-text-light);">
                {job.location}
              </p>
            </div>
          </div>

          <ul class="space-y-1.5 mt-3">
            {job.bullets.map(bullet => (
              <li class="text-sm leading-relaxed pl-4 relative" style="color: var(--color-text-light);">
                <span class="absolute left-0 top-0">&mdash;</span>
                {bullet}
              </li>
            ))}
          </ul>

          {i < siteConfig.experience.length - 1 && (
            <div class="mt-10 md:mt-14 border-b" style="border-color: rgba(26,26,26,0.08);"></div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
