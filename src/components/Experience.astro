---
import { siteConfig } from "../config";
---

<section id="experience" class="py-16 md:py-24 px-6 md:px-24 bg-white">
  <div class="max-w-5xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16">
      <!-- Heading -->
      <div class="lg:col-span-4 reveal">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-4">Experience</h2>
        <div class="accent-bar"></div>
      </div>

      <!-- Timeline -->
      <div class="lg:col-span-8 space-y-0">
        {siteConfig.experience.map((job, i) => (
          <div class={`reveal stagger-${Math.min(i + 1, 6)}`}>
            <!-- Timeline dot + line -->
            <div class="flex gap-6">
              <div class="flex flex-col items-center">
                <div
                  class="timeline-dot w-4 h-4 rounded-full border-2 flex-shrink-0 mt-1.5"
                  style="border-color: var(--color-accent); background-color: var(--color-accent);"
                ></div>
                {i < siteConfig.experience.length - 1 && (
                  <div class="w-0.5 flex-1 min-h-[48px] bg-gray-200"></div>
                )}
              </div>

              <!-- Card -->
              <div class="pb-8 flex-1">
                <div class="bg-white border border-gray-100 rounded-xl p-5 shadow-sm card-hover">
                  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-1 mb-3">
                    <div>
                      <h3 class="text-lg font-semibold text-gray-900">{job.title}</h3>
                      <p class="text-base font-medium" style="color: var(--color-accent);">{job.company}</p>
                    </div>
                    <div class="text-right">
                      <p class="text-xs text-gray-500" style="font-family: 'IBM Plex Mono', monospace;">{job.dateRange}</p>
                      <p class="text-xs text-gray-400">{job.location}</p>
                    </div>
                  </div>
                  <ul class="space-y-2">
                    {job.bullets.map(bullet => (
                      <li class="flex items-start gap-2 text-sm text-gray-600">
                        <span class="w-1.5 h-1.5 rounded-full mt-2 flex-shrink-0" style="background-color: var(--color-accent); opacity: 0.5;"></span>
                        {bullet}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
