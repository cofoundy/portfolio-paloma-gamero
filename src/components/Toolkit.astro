---
import { siteConfig } from "../config";

// Merge tools and competencies into a single keyword cloud
const allSkills = [
  ...siteConfig.competencies,
  ...siteConfig.tools.map(t => t.name),
];
---

<section id="toolkit" class="py-16 md:py-24 px-6 md:px-12">
  <div class="max-w-4xl mx-auto">
    <div class="mb-10 reveal">
      <p class="label-upper mb-4">Skills & Tools</p>
    </div>

    <!-- Keyword cloud as pills -->
    <div class="flex flex-wrap justify-center gap-3 reveal stagger-1">
      {allSkills.map(skill => (
        <span
          class="px-4 py-2 text-xs md:text-sm uppercase tracking-[0.1em] rounded-full border transition-colors duration-200 hover:bg-[var(--color-dark)] hover:text-[var(--color-cream)]"
          style="border-color: rgba(26,26,26,0.2); color: var(--color-text);"
        >
          {skill}
        </span>
      ))}
    </div>
  </div>
</section>
