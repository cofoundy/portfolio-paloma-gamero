---
import { siteConfig } from "../config";

const toolIcons: Record<string, string> = {
  "Photoshop": "Ps",
  "Canva": "Ca",
  "Excel": "Xl",
  "Asana": "As",
  "Microsoft Teams": "Mt",
};
---

<section id="toolkit" class="py-16 md:py-24 px-6 md:px-24" style="background-color: var(--color-surface);">
  <div class="max-w-5xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16">
      <!-- Heading -->
      <div class="lg:col-span-4 reveal">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-4">Toolkit</h2>
        <div class="accent-bar"></div>
      </div>

      <!-- Tools -->
      <div class="lg:col-span-8 reveal stagger-1">
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          {siteConfig.tools.map((tool, i) => (
            <div class={`tool-pill flex items-center gap-3 bg-white border border-gray-200 rounded-xl p-4 cursor-default reveal stagger-${Math.min(i + 1, 6)}`}>
              <div
                class="w-10 h-10 rounded-lg flex items-center justify-center text-white text-xs font-bold flex-shrink-0"
                style="background-color: var(--color-accent); font-family: 'IBM Plex Mono', monospace;"
              >
                {toolIcons[tool.name] || tool.name.slice(0, 2)}
              </div>
              <div>
                <p class="text-sm font-medium text-gray-900">{tool.name}</p>
                <p class="text-xs text-gray-400">{tool.category}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
