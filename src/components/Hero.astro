---
import { siteConfig } from "../config";
---

<section id="hero" class="relative min-h-screen flex items-center bg-white overflow-hidden">
  <!-- Grid pattern background (like Judith's style) -->
  <div class="absolute inset-0 opacity-[0.03]">
    <svg width="100%" height="100%">
      <defs>
        <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#111827" stroke-width="1"/>
        </pattern>
        <radialGradient id="grid-fade" cx="30%" cy="30%">
          <stop offset="0%" stop-color="white" stop-opacity="1"/>
          <stop offset="70%" stop-color="white" stop-opacity="0"/>
        </radialGradient>
        <mask id="grid-mask">
          <rect width="100%" height="100%" fill="url(#grid-fade)"/>
        </mask>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)" mask="url(#grid-mask)"/>
    </svg>
  </div>

  <!-- Accent gradient orb -->
  <div class="absolute top-0 left-0 w-[600px] h-[600px] rounded-full opacity-[0.06]"
       style="background: radial-gradient(circle, var(--color-accent) 0%, transparent 70%);"></div>

  <div class="relative z-10 max-w-5xl mx-auto px-6 py-24 md:py-0 w-full">
    <div class="flex flex-col md:flex-row items-center gap-12 md:gap-16">
      <!-- Photo -->
      <div class="hero-photo flex-shrink-0">
        <div class="w-40 h-40 md:w-52 md:h-52 rounded-full overflow-hidden border-4" style="border-color: var(--color-accent);">
          <img
            src="/profile.jpg"
            alt={siteConfig.name}
            class="w-full h-full object-cover object-top"
            loading="eager"
          />
        </div>
      </div>

      <!-- Content -->
      <div class="text-center md:text-left flex-1">
        <p class="hero-greeting text-lg md:text-xl text-gray-500 mb-2" style="font-family: 'IBM Plex Mono', monospace;">
          Hello!
        </p>
        <h1 class="hero-name text-4xl md:text-6xl lg:text-7xl font-bold text-gray-800 tracking-tight leading-tight mb-2">
          <span style="color: var(--color-accent);">{siteConfig.name.split(' ')[0]}</span>{' '}
          {siteConfig.name.split(' ').slice(1).join(' ')}
        </h1>
        <p class="hero-title text-lg md:text-xl text-gray-600 font-medium mb-6">
          {siteConfig.title}
        </p>
        <p class="hero-tagline text-base md:text-lg text-gray-500 max-w-lg mb-8 leading-relaxed">
          {siteConfig.tagline}
        </p>

        <!-- Stats -->
        <div class="hero-stats flex justify-center md:justify-start gap-8 mb-8">
          {siteConfig.stats.map((stat) => (
            <div class="text-center">
              <div class="text-2xl md:text-3xl font-bold" style="color: var(--color-accent); font-family: 'IBM Plex Mono', monospace;">
                {stat.value}
              </div>
              <div class="text-xs md:text-sm text-gray-500 mt-1">{stat.label}</div>
            </div>
          ))}
        </div>

        <!-- CTAs -->
        <div class="hero-cta flex justify-center md:justify-start gap-4">
          <a
            href="#work"
            class="px-6 py-3 rounded-lg text-white text-sm font-medium transition-all duration-300 hover:opacity-90 hover:shadow-lg"
            style="background-color: var(--color-accent);"
          >
            View My Work
          </a>
          <a
            href={siteConfig.social.linkedin}
            target="_blank"
            rel="noopener"
            class="px-6 py-3 rounded-lg text-sm font-medium border transition-all duration-300 hover:bg-gray-50"
            style="border-color: var(--color-primary-light); color: var(--color-primary);"
          >
            LinkedIn
          </a>
        </div>
      </div>
    </div>

    <!-- Social links at bottom -->
    <div class="hero-social absolute bottom-8 left-6 hidden md:flex flex-col gap-4">
      <a href={`mailto:${siteConfig.social.email}`} class="text-gray-400 hover:text-gray-600 transition-colors" aria-label="Email">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
      </a>
      <a href={siteConfig.social.linkedin} target="_blank" rel="noopener" class="text-gray-400 hover:text-gray-600 transition-colors" aria-label="LinkedIn">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
    </div>
  </div>
</section>
