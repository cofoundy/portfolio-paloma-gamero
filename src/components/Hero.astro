---
import { siteConfig } from "../config";

const firstName = siteConfig.name.split(' ')[0].toUpperCase();
const lastName = siteConfig.name.split(' ').slice(1).join(' ').toUpperCase();
---

<section id="hero" class="relative min-h-screen flex items-end pb-16 md:pb-24 overflow-hidden">
  <div class="relative z-10 w-full max-w-[1400px] mx-auto px-6 md:px-12">
    <!-- Layout: Name text + Photo -->
    <div class="grid grid-cols-1 md:grid-cols-12 items-end gap-6 md:gap-0">
      <!-- Name + Subtitle (takes most of the width) -->
      <div class="md:col-span-8 lg:col-span-9">
        <!-- Subtitle above name -->
        <p class="hero-subtitle label-upper mb-4 md:mb-6">
          {siteConfig.title.toUpperCase()}
        </p>

        <!-- Giant display name -->
        <h1 class="hero-name display-giant">
          <span class="block">{firstName}</span>
          <span class="block">{lastName}</span>
        </h1>

        <!-- Tagline below -->
        <p class="hero-tagline mt-6 md:mt-8 text-base md:text-lg max-w-lg leading-relaxed" style="color: var(--color-text-light);">
          {siteConfig.tagline}
        </p>
      </div>

      <!-- Photo (overlaps slightly on desktop) -->
      <div class="md:col-span-4 lg:col-span-3 flex justify-center md:justify-end">
        <div class="hero-photo w-48 h-64 md:w-64 md:h-80 lg:w-72 lg:h-96 overflow-hidden rounded-sm">
          <img
            src="/profile.jpg"
            alt={siteConfig.name}
            class="w-full h-full object-cover object-top"
            loading="eager"
          />
        </div>
      </div>
    </div>

    <!-- Bottom bar: stats + scroll hint -->
    <div class="mt-10 md:mt-14 flex flex-wrap items-center gap-8 md:gap-12 hero-tagline">
      {siteConfig.stats.map((stat) => (
        <div>
          <span class="text-2xl md:text-3xl font-bold" style="font-family: var(--font-display);">
            {stat.value}
          </span>
          <span class="ml-2 text-xs uppercase tracking-wider" style="color: var(--color-text-light);">
            {stat.label}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>
