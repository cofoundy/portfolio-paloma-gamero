---
import { siteConfig } from "../config";
---

<section id="about" class="py-20 md:py-32 px-6 md:px-12">
  <div class="max-w-3xl mx-auto text-center">
    <p class="label-upper mb-6 reveal">About</p>

    <p class="reveal stagger-1 text-xl md:text-2xl lg:text-3xl leading-relaxed" style="color: var(--color-text); font-family: var(--font-display); font-weight: 400;">
      {siteConfig.aboutMe}
    </p>

    <!-- Languages as inline text -->
    <div class="mt-10 reveal stagger-2">
      <p class="text-sm tracking-wider uppercase" style="color: var(--color-text-light);">
        {siteConfig.languages.map((lang, i) => (
          <span>
            {lang.name} ({lang.level}){i < siteConfig.languages.length - 1 ? <span class="mx-2">&mdash;</span> : ''}
          </span>
        ))}
      </p>
    </div>
  </div>
</section>
