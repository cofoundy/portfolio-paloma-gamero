---
import { siteConfig } from "../config";
---

<section id="about" class="py-16 md:py-24 px-6 md:px-24 bg-white">
  <div class="max-w-5xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16">
      <!-- Heading (left column) -->
      <div class="lg:col-span-4 reveal">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-4">About Me</h2>
        <div class="accent-bar"></div>
      </div>

      <!-- Content (right column) -->
      <div class="lg:col-span-8 reveal stagger-1">
        <p class="text-lg md:text-xl text-gray-600 leading-relaxed mb-10">
          {siteConfig.aboutMe}
        </p>

        <!-- Language Visualization (UNIQUE COMPONENT) -->
        <div class="space-y-5">
          <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-widest mb-4" style="font-family: 'IBM Plex Mono', monospace;">
            Languages
          </h3>
          {siteConfig.languages.map((lang, i) => (
            <div class="reveal" style={`transition-delay: ${(i + 2) * 150}ms;`}>
              <div class="flex items-center justify-between mb-2">
                <span class="text-sm font-medium text-gray-800">{lang.name}</span>
                <span class="text-xs text-gray-500" style="font-family: 'IBM Plex Mono', monospace;">{lang.level}</span>
              </div>
              <div class="w-full h-2 bg-gray-100 rounded-full overflow-hidden">
                <div
                  class="h-full rounded-full lang-bar-fill"
                  style={`--bar-width: ${lang.percent}%; width: ${lang.percent}%; background-color: var(--color-accent); opacity: ${lang.percent === 100 ? '1' : '0.7'}; animation-delay: ${(i + 1) * 200}ms;`}
                ></div>
              </div>
            </div>
          ))}
        </div>

        <!-- Competencies -->
        <div class="mt-10 reveal stagger-4">
          <div class="flex flex-wrap gap-2">
            {siteConfig.competencies.map(skill => (
              <span class="tool-pill px-3 py-1.5 text-sm font-medium bg-gray-100 text-gray-800 rounded-lg hover:bg-gray-200 cursor-default">
                {skill}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
